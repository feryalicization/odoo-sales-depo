<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="group_sales_depo_user" model="res.groups">
        <field name="name">Sales Depo User</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="comment">Read assigned regions and depos.</field>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
    </record>

    <record id="group_sales_depo_supervisor" model="res.groups">
        <field name="name">Depo Supervisor</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="comment">Supervise assigned depos.</field>
        <field name="implied_ids" eval="[(4, ref('sales_depo_management.group_sales_depo_user'))]"/>
    </record>

    <record id="group_sales_depo_region_manager" model="res.groups">
        <field name="name">Regional Manager</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="comment">Read regions and depos managed through the region manager assignment.</field>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
    </record>

    <record id="group_sales_depo_master_manager" model="res.groups">
        <field name="name">Sales Depo Manager</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="comment">Manage sales regions and depos from the Sales configuration menu.</field>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
