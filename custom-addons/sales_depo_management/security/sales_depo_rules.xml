<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <record id="sales_region_company_rule" model="ir.rule">
        <field name="name">Sales Region multi-company</field>
        <field name="model_id" ref="sales_depo_management.model_sales_region"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="sales_depo_company_rule" model="ir.rule">
        <field name="name">Sales Depo multi-company</field>
        <field name="model_id" ref="sales_depo_management.model_sales_depo"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="sales_region_user_rule" model="ir.rule">
        <field name="name">Sales Region assigned depos</field>
        <field name="model_id" ref="sales_depo_management.model_sales_region"/>
        <field name="groups" eval="[(4, ref('sales_depo_management.group_sales_depo_user')), (4, ref('sales_depo_management.group_sales_depo_supervisor'))]"/>
        <field name="domain_force">[('id', 'in', user.depo_ids.region_id.ids)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="sales_depo_user_rule" model="ir.rule">
        <field name="name">Sales Depo assigned depos</field>
        <field name="model_id" ref="sales_depo_management.model_sales_depo"/>
        <field name="groups" eval="[(4, ref('sales_depo_management.group_sales_depo_user')), (4, ref('sales_depo_management.group_sales_depo_supervisor'))]"/>
        <field name="domain_force">[('id', 'in', user.depo_ids.ids)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="sales_region_regional_manager_rule" model="ir.rule">
        <field name="name">Sales Region regional manager</field>
        <field name="model_id" ref="sales_depo_management.model_sales_region"/>
        <field name="groups" eval="[(4, ref('sales_depo_management.group_sales_depo_region_manager'))]"/>
        <field name="domain_force">[('manager_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="sales_depo_regional_manager_rule" model="ir.rule">
        <field name="name">Sales Depo regional manager</field>
        <field name="model_id" ref="sales_depo_management.model_sales_depo"/>
        <field name="groups" eval="[(4, ref('sales_depo_management.group_sales_depo_region_manager'))]"/>
        <field name="domain_force">['|', ('region_id.manager_id', '=', user.id), ('manager_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="sales_region_manager_rule" model="ir.rule">
        <field name="name">Sales Region manager full access</field>
        <field name="model_id" ref="sales_depo_management.model_sales_region"/>
        <field name="groups" eval="[(4, ref('sales_depo_management.group_sales_depo_master_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="sales_depo_manager_rule" model="ir.rule">
        <field name="name">Sales Depo manager full access</field>
        <field name="model_id" ref="sales_depo_management.model_sales_depo"/>
        <field name="groups" eval="[(4, ref('sales_depo_management.group_sales_depo_master_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
