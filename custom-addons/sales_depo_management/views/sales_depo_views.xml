<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sales_depo_list" model="ir.ui.view">
        <field name="name">sales.depo.list</field>
        <field name="model">sales.depo</field>
        <field name="arch" type="xml">
            <list string="Depos" default_order="company_id, region_id, name">
                <field name="name"/>
                <field name="code"/>
                <field name="region_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="warehouse_id" optional="show"/>
                <field name="manager_id" widget="many2one_avatar_user" optional="show"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_sales_depo_form" model="ir.ui.view">
        <field name="name">sales.depo.form</field>
        <field name="model">sales.depo</field>
        <field name="arch" type="xml">
            <form string="Depo">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="region_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="warehouse_id"/>
                            <field name="manager_id" widget="many2one_avatar_user"/>
                            <field name="user_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group>
                        <field name="address" placeholder="Operational address"/>
                    </group>
                    <group>
                        <field name="phone"/>
                        <field name="email"/>
                    </group>
                    <group>
                        <field name="description" placeholder="Internal notes about this depo..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sales_depo_search" model="ir.ui.view">
        <field name="name">sales.depo.search</field>
        <field name="model">sales.depo</field>
        <field name="arch" type="xml">
            <search string="Search Depos">
                <field name="name"/>
                <field name="code"/>
                <field name="region_id"/>
                <field name="company_id"/>
                <field name="warehouse_id"/>
                <field name="manager_id"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Company" name="group_by_company" context="{'group_by': 'company_id'}"/>
                    <filter string="Region" name="group_by_region" context="{'group_by': 'region_id'}"/>
                    <filter string="Manager" name="group_by_manager" context="{'group_by': 'manager_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sales_depo" model="ir.actions.act_window">
        <field name="name">Depos</field>
        <field name="res_model">sales.depo</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="sales_depo_management.view_sales_depo_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first sales depo
            </p>
            <p>
                Depos link operational sales areas to regions and warehouses.
            </p>
        </field>
    </record>
</odoo>
