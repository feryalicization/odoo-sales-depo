<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sales_region_list" model="ir.ui.view">
        <field name="name">sales.region.list</field>
        <field name="model">sales.region</field>
        <field name="arch" type="xml">
            <list string="Regions" default_order="company_id, name">
                <field name="name"/>
                <field name="code"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="manager_id" widget="many2one_avatar_user" optional="show"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_sales_region_form" model="ir.ui.view">
        <field name="name">sales.region.form</field>
        <field name="model">sales.region</field>
        <field name="arch" type="xml">
            <form string="Region">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="manager_id" widget="many2one_avatar_user"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Internal notes about this region..."/>
                    </group>
                    <notebook>
                        <page string="Depos">
                            <field name="depo_ids" readonly="1">
                                <list string="Depos">
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="warehouse_id"/>
                                    <field name="manager_id" widget="many2one_avatar_user" optional="show"/>
                                    <field name="active" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sales_region_search" model="ir.ui.view">
        <field name="name">sales.region.search</field>
        <field name="model">sales.region</field>
        <field name="arch" type="xml">
            <search string="Search Regions">
                <field name="name"/>
                <field name="code"/>
                <field name="company_id"/>
                <field name="manager_id"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Company" name="group_by_company" context="{'group_by': 'company_id'}"/>
                    <filter string="Manager" name="group_by_manager" context="{'group_by': 'manager_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sales_region" model="ir.actions.act_window">
        <field name="name">Regions</field>
        <field name="res_model">sales.region</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="sales_depo_management.view_sales_region_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first sales region
            </p>
            <p>
                Regions organize depos within each company before downstream sales flows are added.
            </p>
        </field>
    </record>
</odoo>
