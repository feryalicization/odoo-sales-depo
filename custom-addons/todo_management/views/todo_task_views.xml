<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_todo_task_tree" model="ir.ui.view">
        <field name="name">todo.task.tree</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <list string="Tasks">
                <field name="name"/>
                <field name="user_id"/>
                <field name="date_deadline"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_todo_task_form" model="ir.ui.view">
        <field name="name">todo.task.form</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <form string="Task">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="user_id"/>
                            <field name="date_deadline"/>
                        </group>
                        <group>
                            <field name="priority"/>
                            <field name="state"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Save" type="object" special="save" class="btn btn-primary"/>
                    <button string="Discard" special="cancel" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_todo_task_search" model="ir.ui.view">
        <field name="name">todo.task.search</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <search string="Tasks">
                <field name="name"/>
                <field name="user_id"/>
                <field name="state"/>
                <filter name="filter_my_tasks" string="My Tasks" domain="[('user_id', '=', uid)]"/>
                <filter name="filter_todo" string="To Do" domain="[('state', '=', 'todo')]"/>
                <filter name="filter_in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                <filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter name="filter_archived" string="Archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_user" string="Assignee" context="{'group_by': 'user_id'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_todo_task" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">todo.task</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="todo_management.view_todo_task_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first task</p>
        </field>
    </record>
</odoo>
